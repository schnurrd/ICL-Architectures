    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Pre-training Transformer",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/PFNs/pfns/run_training_cli.py",
            "console": "integratedTerminal",
            "python": "${userHome}/miniconda3/envs/icl_arch/bin/python",
            "args": [
                "PFNs/configs/transformer/transformer_config.py", 
                "--checkpoint-save-load-prefix", "PFNs/models_diff",
                "--config-arg", "training_setup='low'",
                "--overwrite", "--no-wandb",
                "--config-arg", "interleave_x_y_pairs=True",
            ]
        },
        {
            "name": "Python Debugger: Pre-training Masked Transformer",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/PFNs/pfns/run_training_cli.py",
            "console": "integratedTerminal",
            "python": "${userHome}/miniconda3/envs/icl_arch/bin/python",
            "args": [
                "PFNs/configs/transformer_experiments/tabpfn_transformer_masking.py", 
                "--checkpoint-save-load-prefix", "PFNs/models_diff",
                "--config-arg", "masking='causal_all'",
                "--overwrite", "--no-wandb",
            ]
        },
        {
            "name": "Python Debugger: Pre-training FLA Config",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/PFNs/pfns/run_training_cli.py",
            "console": "integratedTerminal",
            "python": "${userHome}/miniconda3/envs/icl_arch/bin/python",
            "args": [
                "PFNs/configs/fla/fla_config.py",
                "--checkpoint-save-load-prefix", "PFNs/models_diff",
                "--overwrite", "--no-wandb",
                "--config-arg", "model_type='deltanet'",
                "--config-arg", "sequence_mode='comb_st'",
                //"--config-arg", "interleaved_pair_positional_embedding='sinusoidal'" 
                "--config-arg", "bidirectional=True",
                // "--config-arg", "bidirectional_test_time=True",
                // "--config-arg", "mimetic_init=True",
                // "--config-arg", "sequence_mode='cached'",
                // "--config-arg", "cache_chunk_size=None",
                // "--config-arg", "training_setup='low'",
                // "--config-arg", "batch_size=2",
                // "--config-index", "-1"
            ],
            "justMyCode": false
        },
        {
            "name": "Python Debugger: Pre-training FLA Config Bugfix",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/PFNs/pfns/run_training_cli.py",
            "console": "integratedTerminal",
            "python": "${userHome}/miniconda3/envs/icl_arch/bin/python",
            "args": [
                "PFNs/configs/fla/fla_config.py",
                "--checkpoint-save-load-prefix", "PFNs/models_diff",
                "--no-wandb",
                "--config-arg", "model_type='gla'",
                "--config-arg", "sequence_mode='cached'",
                "--config-arg", "training_setup='low'",
                "--config-arg", "interleave_x_y_pairs=True",
                "--config-arg", "feature_positional_embedding=None",
                "--config-index", "0"
            ],
            "justMyCode": false
        },
        {
            "name": "Python Debugger: Pre-training Linear Attention",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/PFNs/pfns/run_training_cli.py",
            "console": "integratedTerminal",
            "python": "${userHome}/miniconda3/envs/icl_arch/bin/python",
            "args": [
                "PFNs/configs/linear_attention/linear_attention_config.py",
                "--checkpoint-save-load-prefix", "PFNs/models_diff",
                "--overwrite", "--no-wandb",
                "--config-arg", "sequence_mode='Comb_ST'",
                "--config-arg", "norm_type='rmsnorm'",
                "--config-arg", "use_output_norm=True",
                "--config-arg", "scale_query_by_sqrt_dk=True",
                "--config-arg", "use_k_sum_normalization=False",
                "--config-arg", "state_renormalization='sqrt_d_fro'",
                "--config-arg", "learnable_state_renorm_scale=True"
            ],
            "justMyCode": false
        },
        {
            "name": "Python Debugger: Evaluation Transformer",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/PFNs/pfns/run_evaluation_cli.py",
            "console": "integratedTerminal",
            "python": "${userHome}/miniconda3/envs/icl_arch/bin/python",
            "args": [
                //"--wandb_run_id", "tabpfn_transformer/runs/rpichg7o",
                "--model_path", "PFNs/models_diff/transformer_config_0_training_setup_debug", 
                "--only_tabpfn", 
                "--max_features", "20",
                "--max_samples", "1000",
            ]
        },
        {
            "name": "Python Debugger: Evaluation FLA",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/PFNs/pfns/run_evaluation_cli.py",
            "console": "integratedTerminal",
            "python": "${userHome}/miniconda3/envs/icl_arch/bin/python",
            "args": [
                "--model_path", "PFNs/models_diff/fla_mamba_teacher_forcing_performance_0", 
                "--only_tabpfn", 
                "--max_features", "20",
                "--max_samples", "1000",
                "--sample_order_permutation"
            ],
            "justMyCode": true
        },
        {
            "name": "Python Debugger: Model Spike Analysis",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/PFNs/pfns/scripts/analyze_spike_batch.py",
            "console": "integratedTerminal",
            "python": "${userHome}/miniconda3/envs/icl_arch/bin/python",
            "args": [
                "--checkpoint", "PFNs/models_diff/tabpfn_prior_config_1_gpu_v4_performance_long_2_2/checkpoint.pt", 
                "--spike", "PFNs/models_diff/tabpfn_prior_config_1_gpu_v4_performance_long_2_2/spike_epoch58_step120.pt",
            ]
        },
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "python": "${userHome}/miniconda3/envs/icl_arch/bin/python",
            "justMyCode": false
        },
        {
            "name": "Python Debugger: Real World Experiments",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/PFNs/notebooks/run_real_world_experiments.py",
            "console": "integratedTerminal",
            "python": "${userHome}/miniconda3/envs/icl_arch/bin/python",
            "args": [
                // "--num-runs", "1",
                // "--run-index", "0",
                // "--include-baselines",
                "--models", "Oracle_Hidden_State_DeltaNet_Comb_ST_base"
            ]
        },
        {
            "name": "Python Debugger: Length Generalization Experiments",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/PFNs/notebooks/run_synthetic_seq_len_experiments.py",
