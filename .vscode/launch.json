{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Pre-training",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/PFNs/pfns/run_training_cli.py",
            "console": "integratedTerminal",
            "python": "${userHome}/miniconda3/envs/icl_arch_pfn/bin/python",
            "args": [
                "PFNs/configs/tabpfn_prior_config_1_gpu_10h_v2.py", // tabpfn_prior_config_1_gpu_10h tabpfn_prior_config_very_large_gla
                "--checkpoint-save-load-prefix", "PFNs/models_diff/checkpoint.pt",
                "--tensorboard-path", "PFNs/tensorboards", "--overwrite"
            ]
        },
        {
            "name": "Python Debugger: Evaluation",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/PFNs/pfns/run_evaluation_cli.py",
            "console": "integratedTerminal",
            "python": "${userHome}/miniconda3/envs/icl_arch_pfn/bin/python",
            "args": [
                "--model_path", "PFNs/models_diff/large_config_backbone_new2.pt/tabpfn_prior_config_very_large_0_no_seed", 
                "--only_tabpfn", 
                "--max_features", "20"
            ]
        }
    ]
}